# Copy to `.env.local` and fill in values used by the Vite client (`npm run dev`).

VITE_API_MODE=real
# Leave empty when the SPA is served from the API host (Docker/CloudFront) so /api and /hubs use same origin.
# For Vite dev against a separate API port, set e.g. http://localhost:5032
VITE_API_BASE_URL=

# Required for Mapbox GL on live / ride-live pages (https://account.mapbox.com/)
# Docker full-stack: also set this in the repo ROOT `.env` (see `/.env.example`) so
# `docker compose build` passes it into the Vite build; `client/.env.local` is not used there.
VITE_MAPBOX_ACCESS_TOKEN=
