# Copy to `.env.local` and fill in values used by the Vite client (`npm run dev`).

VITE_API_MODE=real
# Verbose [rydo:ride-live] browser logs when not using Vite dev (e.g. Docker :5000). Also: ?debugRideLive=1 or localStorage rydo_debug_ride_live=1
# VITE_LOG_RIDE_LIVE=true
# Leave empty when the SPA is served from the API host (Docker/CloudFront) so /api and /hubs use same origin.
# For Vite dev: leave empty and use server.proxy in vite.config (default target Docker API :5000).
# Required for phone-on-LAN (https://<your-ip>:5173). Do not set http://localhost:… here — on a phone,
# localhost is the phone, not your PC.
# For `dotnet run` API on port 5032 instead of Docker :5000, set:
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:5032
VITE_API_BASE_URL=

# Required for Mapbox GL on live / ride-live pages (https://account.mapbox.com/)
# Docker full-stack: also set this in the repo ROOT `.env` (see `/.env.example`) so
# `docker compose build` passes it into the Vite build; `client/.env.local` is not used there.
VITE_MAPBOX_ACCESS_TOKEN=
