# Copy to deploy.env and adjust (deploy.env is gitignored).
# scripts/deploy-aws.sh loads infra/deploy.env

# Required: region for CDK, ECR, ECS, and CLI
AWS_REGION=us-east-1

# Optional: named AWS CLI profile (~/.aws/credentials)
# AWS_PROFILE=my-profile

# CloudFormation stack id (must match infra/bin/rydo.ts)
CDK_STACK_NAME=RydoStack

# Docker image name/tag pushed to ECR (must match CDK ECR repo + task definition)
IMAGE_NAME=rydo-app
IMAGE_TAG=latest

# Set to 1 to skip "cdk deploy" (only build, push, and roll ECS — stack must exist)
# SKIP_CDK_DEPLOY=0
