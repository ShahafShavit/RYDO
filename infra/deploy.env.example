# Optional overrides for scripts/deploy-aws.sh, ecs-scale.sh, destroy-aws.sh.
# If this file is missing, region/profile come from your AWS CLI config (aws configure).

# Baked into the Vite client at docker build (Mapbox on live / ride-live pages).
# Also read from client/.env.local when unset here.
# VITE_MAPBOX_ACCESS_TOKEN=pk.

# AWS_REGION=us-east-1
# AWS_PROFILE=my-profile

# CDK_STACK_NAME=RydoStack
# IMAGE_NAME=rydo-app
# IMAGE_TAG=latest
# DESIRED_COUNT_ON=1
