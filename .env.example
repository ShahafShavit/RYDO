# Used by Docker Compose (variable substitution). Copy to `.env` in this folder.
# client/.env.local is only for `npm run dev` — it is not copied into the image build.

VITE_MAPBOX_ACCESS_TOKEN=

# Optional: override for timelapse-renderer. If omitted, Compose passes VITE_MAPBOX_ACCESS_TOKEN instead (same token).
MAPBOX_ACCESS_TOKEN=
