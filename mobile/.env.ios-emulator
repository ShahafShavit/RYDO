# iOS Simulator — API on the host machine (Docker Compose default)
# Applied by: npm run env:ios  →  writes mobile/.env.local
# Vite mode (when scaffold exists): vite build --mode ios-emulator

VITE_API_MODE=real
VITE_API_BASE_URL=http://127.0.0.1:5000
VITE_PLATFORM=native

# Copy from client/.env.local or set here (required for live ride / Mapbox pages)
VITE_MAPBOX_ACCESS_TOKEN=

# VITE_LOG_RIDE_LIVE=true
