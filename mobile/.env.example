# Mobile env templates — do not copy this file directly for emulators.
# Use the platform scripts instead:
#   npm run env:ios
#   npm run env:android
#
# Those write mobile/.env.local from .env.ios-emulator or .env.android-emulator.

VITE_API_MODE=real
VITE_PLATFORM=native

# Emulator (see committed templates):
#   iOS Simulator     → http://127.0.0.1:5000   (.env.ios-emulator)
#   Android Emulator  → http://10.0.2.2:5000    (.env.android-emulator)
#   dotnet run API    → :5032 on host           (.env.*-emulator.dotnet)

# Physical device on LAN (create your own .env.local):
# VITE_API_BASE_URL=http://192.168.x.x:5000

VITE_MAPBOX_ACCESS_TOKEN=
