{
  "name": "rydo-mobile",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Capacitor shell for RYDO — reuses client/src via Vite alias",
  "scripts": {
    "env:ios": "node scripts/use-emulator-env.mjs ios",
    "env:android": "node scripts/use-emulator-env.mjs android",
    "env:android:device": "node scripts/use-emulator-env.mjs android-device",
    "env:ios:dotnet": "node scripts/use-emulator-env.mjs ios --dotnet",
    "env:android:dotnet": "node scripts/use-emulator-env.mjs android --dotnet",
    "env:android:device:dotnet": "node scripts/use-emulator-env.mjs android-device --dotnet",
    "env:show": "node scripts/use-emulator-env.mjs show",
    "prebuild": "node scripts/ensure-env.mjs",
    "build": "vite build",
    "build:android": "npm run build && npx cap sync android",
    "dev": "vite",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:sync:android": "npx cap sync android",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "env:shell": "bash scripts/android-env.sh",
    "check:android": "node scripts/check-android-prereqs.mjs",
    "run:android": "node scripts/check-android-prereqs.mjs && node scripts/run-android.mjs",
    "run:android:dotnet": "node scripts/check-android-prereqs.mjs && node scripts/run-android.mjs --dotnet"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/geolocation": "^7.1.8",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/preferences": "^7.0.4",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@microsoft/signalr": "^8.0.7",
    "@studio-freight/lenis": "^1.0.42",
    "@tanstack/react-query": "^5.96.2",
    "@tmcw/togeojson": "^7.1.2",
    "@turf/along": "^7.3.4",
    "@turf/bearing": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "@turf/length": "^7.3.4",
    "@turf/line-slice": "^7.3.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "mapbox-gl": "^3.21.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^8.1.1",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "vite": "^8.0.1"
  }
}
